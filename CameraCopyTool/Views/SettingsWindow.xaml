<Window x:Class="CameraCopyTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="14"/>
            <Setter Property="Maximum" Value="28"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Font Size" FontWeight="Bold" Grid.Row="0"
                   FontSize="{Binding FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>

        <StackPanel Grid.Row="1" Margin="0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="FontSizeSlider"
                        Grid.Column="0"
                        Minimum="14" Maximum="28"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                        ValueChanged="FontSizeSlider_ValueChanged"/>
                <TextBlock x:Name="FontSizeValueText" 
                           Grid.Column="1" 
                           Text="{Binding ElementName=FontSizeSlider, Path=Value, StringFormat={}{0:F0}px}"
                           MinWidth="40"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>
            
            <TextBlock Text="Preview:" Margin="0,15,0,5" FontWeight="Bold"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" CornerRadius="4">
                <TextBlock x:Name="PreviewText" 
                           Text="The quick brown fox jumps over the lazy dog"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Reset to Default" Width="100" Margin="0,0,10,0" Click="ResetButton_Click"/>
            <Button Content="OK" Width="80" IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
