<Window x:Class="CameraCopyTool.Views.FileConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Already Exists"
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="White">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Icon -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="📁"
                       FontSize="48"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="File Already Exists"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,10"/>

            <TextBlock Text="A file with the same name already exists on Google Drive."
                       Foreground="#666666"
                       FontSize="14"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- File Information -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="File Name:"
                           Foreground="#666666"
                           FontSize="12"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="FileNameText"
                           Text="filename.mp4"
                           FontWeight="Medium"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Size:"
                           Foreground="#666666"
                           FontSize="12"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="FileSizeText"
                           Text="0 MB"
                           FontWeight="Medium"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Options -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="What would you like to do?"
                       FontWeight="Medium"
                       FontSize="14"
                       Margin="0,0,0,15"/>

            <!-- Replace Option -->
            <Border x:Name="ReplaceOption"
                    BorderBrush="#2196F3"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,0,10"
                    Cursor="Hand"
                    MouseLeftButtonDown="ReplaceOption_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ReplaceRadio"
                                 IsChecked="True"
                                 Margin="0,0,15,0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Replace"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="Overwrite the existing file with this new version"
                                   Foreground="#666666"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Keep Both Option -->
            <Border x:Name="KeepBothOption"
                    BorderBrush="Transparent"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,0,0,10"
                    Cursor="Hand"
                    MouseLeftButtonDown="KeepBothOption_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="KeepBothRadio"
                                 Margin="0,0,15,0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Keep Both (Rename)"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="Keep the existing file and upload this one with a new name"
                                   Foreground="#666666"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Skip Option -->
            <Border x:Name="SkipOption"
                    BorderBrush="Transparent"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="15"
                    Cursor="Hand"
                    MouseLeftButtonDown="SkipOption_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="SkipRadio"
                                 Margin="0,0,15,0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Skip"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="Don't upload this file"
                                   Foreground="#666666"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="OKButton"
                    Content="OK"
                    Padding="40,12"
                    MinWidth="120"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Click="OKButton_Click"/>
            
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="30,12"
                    MinWidth="120"
                    Margin="15,0,0,0"
                    Background="#9E9E9E"
                    Foreground="White"
                    BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
