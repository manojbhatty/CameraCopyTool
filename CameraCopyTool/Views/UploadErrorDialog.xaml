<Window x:Class="CameraCopyTool.Views.UploadErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Error"
        Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="White">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Icon -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock x:Name="ErrorIcon"
                       Text="⚠️"
                       FontSize="48"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="ErrorTitle"
                       Text="Network Error"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,10"/>

            <TextBlock x:Name="ErrorMessage"
                       Text="No internet connection. Waiting to resume..."
                       Foreground="#666666"
                       FontSize="14"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Error Details -->
        <Border Grid.Row="1"
                Background="#FFF3E0"
                BorderBrush="#FFB74D"
                BorderThickness="1"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock x:Name="ErrorDetails"
                           Text="The upload has been paused due to a network issue. The application will automatically resume when the connection is restored."
                           Foreground="#E65100"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
                
                <!-- Progress indicator for waiting -->
                <StackPanel x:Name="WaitingIndicator" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="0,15,0,0">
                    <Ellipse Width="10" Height="10" Fill="#FF9800" Margin="3,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.5"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="10" Height="10" Fill="#FF9800" Margin="3,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.15">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.5"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="10" Height="10" Fill="#FF9800" Margin="3,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.3">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.3" To="1" Duration="0:0:0.5"
                                                         AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Retry Progress (hidden by default) -->
        <StackPanel Grid.Row="2" x:Name="RetryProgressPanel" Visibility="Collapsed">
            <TextBlock Text="Retrying..."
                       Foreground="#666666"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <ProgressBar IsIndeterminate="True"
                         Height="8"
                         Minimum="0"
                         Maximum="100"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="RetryButton"
                    Content="Retry Now"
                    Padding="30,12"
                    MinWidth="120"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    Click="RetryButton_Click"/>
            
            <Button x:Name="PauseButton"
                    Content="Pause"
                    Padding="30,12"
                    MinWidth="120"
                    Margin="15,0,0,0"
                    Background="#FF9800"
                    Foreground="White"
                    BorderThickness="0"
                    Click="PauseButton_Click"/>
            
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="30,12"
                    MinWidth="120"
                    Margin="15,0,0,0"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
