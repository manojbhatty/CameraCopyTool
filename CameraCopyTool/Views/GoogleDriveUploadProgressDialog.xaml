<Window x:Class="CameraCopyTool.Views.GoogleDriveUploadProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uploading to Google Drive"
        Height="280" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="White">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="☁️ Uploading to Google Drive"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="FileNameText"
                       Text="filename.mp4"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,20"/>
        </StackPanel>

        <!-- Progress Section -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- Progress Bar -->
            <ProgressBar x:Name="UploadProgressBar"
                         Minimum="0" 
                         Maximum="100" 
                         Value="5"
                         Height="30"
                         Margin="0,0,0,15"/>

            <!-- Percentage and Time -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Completed:"
                               FontSize="12"
                               Foreground="#666666"/>
                    <TextBlock x:Name="PercentageText"
                               Text="5%"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#000000"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Time Remaining:"
                               FontSize="12"
                               Foreground="#666666"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TimeText"
                               Text="Calculating..."
                               FontSize="14"
                               FontWeight="Medium"
                               HorizontalAlignment="Right"
                               Foreground="#000000"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Cancel Button -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="20,10"
                    MinWidth="100"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Padding="20,10"
                    MinWidth="100"
                    Margin="10,0,0,0"
                    Click="OkButton_Click"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
