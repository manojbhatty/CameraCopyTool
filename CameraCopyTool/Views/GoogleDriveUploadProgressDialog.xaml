<Window x:Class="CameraCopyTool.Views.GoogleDriveUploadProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uploading to Google Drive" 
        Height="200" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="☁️ Uploading to Google Drive" 
                       FontSize="18" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            
            <TextBlock x:Name="FileNameText" 
                       Text="filename.mp4" 
                       FontSize="13"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,15"/>
        </StackPanel>
        
        <!-- Progress -->
        <StackPanel Grid.Row="1">
            <ProgressBar x:Name="UploadProgressBar" 
                         Height="30" 
                         Minimum="0" 
                         Maximum="100"
                         Margin="0,0,0,10"/>
            
            <TextBlock x:Name="ProgressText" 
                       Text="0%" 
                       FontSize="14" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </StackPanel>
        
        <!-- Cancel Button -->
        <Button Grid.Row="2" 
                Content="Cancel"
                HorizontalAlignment="Right"
                Padding="20,8"
                Click="CancelButton_Click"
                IsEnabled="{Binding ElementName=UploadProgressBar, Path=IsIndeterminate, Converter={StaticResource BoolInvertConverter}, FallbackValue=True}"/>
    </Grid>
</Window>
