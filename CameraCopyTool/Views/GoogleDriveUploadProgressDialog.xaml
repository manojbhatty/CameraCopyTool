<Window x:Class="CameraCopyTool.Views.GoogleDriveUploadProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uploading to Google Drive"
        Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="StatusIcon"
                       Text="☁️"
                       FontSize="48"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <TextBlock Text="Uploading to Google Drive"
                       x:Name="TitleText"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="File Name:"
                           x:Name="FileNameLabel"
                           Foreground="#666666"/>
                <TextBlock x:Name="FileNameText"
                           Text="filename.mp4"
                           TextTrimming="CharacterEllipsis"
                           FontWeight="Medium"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Size:"
                           x:Name="SizeLabel"
                           Foreground="#666666"/>
                <TextBlock x:Name="FileSizeText"
                           Text="0 MB"
                           FontWeight="Medium"/>
            </StackPanel>
        </StackPanel>

        <!-- Progress Section -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <!-- Progress Bar -->
            <ProgressBar x:Name="UploadProgressBar"
                         Minimum="0"
                         Maximum="100"
                         Value="5"
                         Height="30"
                         Margin="0,0,0,15"/>

            <!-- Percentage and Time -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                    <TextBlock x:Name="PercentageLabel"
                               Text="Completed:"
                               Foreground="#666666"/>
                    <TextBlock x:Name="PercentageText"
                               Text="0%"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock x:Name="TimeLabel"
                               Text="Time Remaining:"
                               Foreground="#666666"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TimeText"
                               Text="Calculating..."
                               FontWeight="Medium"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Cancel Button -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="20,10"
                    MinWidth="100"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Padding="20,10"
                    MinWidth="100"
                    Margin="10,0,0,0"
                    Click="OkButton_Click"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
