<Window x:Class="CameraCopyTool.Views.GoogleDriveUploadProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uploading to Google Drive"
        Height="260" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="☁️ Uploading to Google Drive"
                       FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="FileNameText"
                       Text="filename.mp4"
                       FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,15"/>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <ProgressBar x:Name="UploadProgressBar"
                         Height="30"
                         Minimum="0"
                         Maximum="100"
                         Foreground="#4CAF50"
                         Background="#E0E0E0"
                         Margin="0,0,0,15"/>

            <TextBlock x:Name="ProgressText"
                       Text="0%"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                    <TextBlock Text="Speed:"
                               FontSize="12"
                               Foreground="#666666"/>
                    <TextBlock x:Name="SpeedText"
                               Text="Calculating..."
                               FontSize="13"
                               FontWeight="Medium"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Time Remaining:"
                               FontSize="12"
                               Foreground="#666666"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TimeText"
                               Text="Calculating..."
                               FontSize="13"
                               FontWeight="Medium"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Cancel Button -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="20,10"
                    MinWidth="100"
                    Click="CancelButton_Click"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Padding="20,10"
                    MinWidth="100"
                    Margin="10,0,0,0"
                    Click="OkButton_Click"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
