<Window x:Class="CameraCopyTool.Views.GoogleDriveAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign in to Google Drive"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        MinHeight="450">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock x:Name="CloudEmojiText" Text="☁️" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TitleText" Text="Sign in to Google Drive"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,5"/>
            <TextBlock x:Name="SubtitleText" Text="CameraCopyTool"
                       FontSize="14"
                       Foreground="#666666"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Instructions -->
        <Border Grid.Row="1"
                Background="#E8F0FE"
                BorderBrush="#4285F4"
                BorderThickness="1"
                CornerRadius="4"
                Padding="20"
                Margin="0,20,0,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="IntroText" Text="To upload files to Google Drive, you need to sign in with your Google account."
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,15"/>

                    <TextBlock x:Name="HowItWorksText" Text="How it works:"
                               FontWeight="Bold"
                               FontSize="14"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="Step1Text" Text="1. Click 'Sign In' to continue"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="Step2Text" Text="2. Your web browser will open automatically"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,8"
                               FontWeight="Bold"
                               Foreground="#1976D2"/>

                    <TextBlock x:Name="Step3Text" Text="3. Sign in with your Google account"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="Step4Text" Text="4. Grant permission to upload files"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="Step5Text" Text="5. Return here automatically when done"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,15"/>

                    <Border Background="#FFFFFF"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="12">
                        <TextBlock x:Name="InfoText" Text="ℹ️ Your credentials are stored securely and encrypted on this computer."
                                   FontSize="13"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button x:Name="SignInButton" Content="Sign In"
                    Padding="30,12"
                    MinWidth="120"
                    Margin="0,0,10,0"
                    Click="SignInButton_Click"/>

            <Button x:Name="CancelButton" Content="Cancel"
                    Padding="20,10"
                    MinWidth="100"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
