<Window x:Class="CameraCopyTool.Views.GoogleDriveAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign in to Google Drive" 
        Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <Style x:Key="AuthButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#357AE8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E57A8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="☁️" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="Sign in to Google Drive" 
                       FontSize="20" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,5"/>
            <TextBlock Text="CameraCopyTool" 
                       FontSize="14" 
                       Foreground="#666666"
                       HorizontalAlignment="Center"/>
        </StackPanel>
        
        <!-- Instructions -->
        <Border Grid.Row="1" 
                Background="#E8F0FE" 
                BorderBrush="#4285F4" 
                BorderThickness="1"
                CornerRadius="4"
                Padding="20"
                Margin="0,20,0,20">
            <StackPanel>
                <TextBlock Text="To upload files to Google Drive, you need to sign in with your Google account."
                           TextWrapping="Wrap"
                           FontSize="13"
                           Margin="0,0,0,15"/>
                
                <TextBlock Text="How it works:" 
                           FontWeight="Bold"
                           FontSize="13"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="1. Click 'Sign In' to continue"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="2. Your web browser will open automatically"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Margin="0,0,0,5"
                           FontWeight="Bold"
                           Foreground="#1976D2"/>
                
                <TextBlock Text="3. Sign in with your Google account"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="4. Grant permission to upload files"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="5. Return here automatically when done"
                           TextWrapping="Wrap"
                           FontSize="13"/>
                
                <TextBlock Margin="0,15,0,0"
                           FontSize="11"
                           Foreground="#666666"
                           TextWrapping="Wrap">
                    <Run Text="ℹ️ Your credentials are stored securely and encrypted on this computer."/>
                </TextBlock>
            </StackPanel>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button Content="Sign In"
                    Style="{StaticResource AuthButtonStyle}"
                    Click="SignInButton_Click"
                    MinWidth="120"
                    Margin="0,0,10,0"/>
            
            <Button Content="Cancel"
                    Style="{StaticResource CancelButtonStyle}"
                    Click="CancelButton_Click"
                    MinWidth="120"/>
        </StackPanel>
    </Grid>
</Window>
