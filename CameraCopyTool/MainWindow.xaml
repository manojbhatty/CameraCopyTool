<Window x:Class="CameraCopyTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera Copy Tool" Height="600" Width="1000"
        MinHeight="400" MinWidth="800" Closing="Window_Closing">
    <!-- Window resources go here -->
    <Window.Resources>
        <Style TargetType="ListViewItem">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAlreadyCopied}" Value="True">
                    <Setter Property="Background" Value="LightGreen"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- Source panel -->
            <ColumnDefinition Width="120" />
            <!-- Center action -->
            <ColumnDefinition Width="*" />
            <!-- Destination panel -->
        </Grid.ColumnDefinitions>

        <!-- SOURCE PANEL -->
        <Grid Grid.Column="0" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Source textbox + Browse -->
                <RowDefinition Height="*"/>
                <!-- Already copied files -->
                <RowDefinition Height="*"/>
                <!-- New files -->
            </Grid.RowDefinitions>

            <TextBlock Text="Source - Camera" FontWeight="Bold" FontSize="18" Grid.Row="0"/>

            <Grid Margin="0,5" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="77*"/>
                    <ColumnDefinition Width="283*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSourcePath"
                         Height="28"
                         Text="D:\SDCard\DCIM"
                         TextChanged="SourcePath_TextChanged" Grid.ColumnSpan="2"/>

                <Button Grid.Column="2"
                        Content="Browse"
                        Margin="5,0,0,0"
                        Click="BrowseSource_Click"/>
            </Grid>

            <GroupBox Header="Already copied files" Margin="0,10,0,5" Grid.Row="2">
                <ListView x:Name="lvAlreadyCopied" SelectionMode="Extended" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="File Name" Tag="Name"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Modified Date" Tag="ModifiedDate"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <GroupBox Header="New files" Grid.Row="3">
                <ListView x:Name="lvNewFiles" SelectionMode="Extended" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="File Name" Tag="Name"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Modified Date" Tag="ModifiedDate"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

        </Grid>

        <!-- CENTER ACTION -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <Button x:Name="btnCopy"
                    Content="Copy ➜ " FontSize="16" FontWeight="Bold"
                    Height="50"
                    Margin="10" Click="btnCopy_Click"/>
            <ProgressBar x:Name="pbCopyProgress"
             Height="20"
             Margin="10,5"
             Minimum="0"
             Maximum="100"
             Value="0"/>

        </StackPanel>

        <!-- DESTINATION PANEL -->
        <Grid Grid.Column="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Destination textbox + Browse -->
                <RowDefinition Height="*"/>
                <!-- Files in destination -->
            </Grid.RowDefinitions>

            <TextBlock Text="Destination - Computer" FontWeight="Bold" FontSize="18" Grid.Row="0"/>

            <Grid Margin="0,5" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtDestinationPath"
                         Height="28"
                         Text="C:\Users\Public\Pictures"
                         TextChanged="DestinationPath_TextChanged"/>

                <Button Grid.Column="1"
                        Content="Browse"
                        Margin="5,0,0,0"
                        Click="BrowseDestination_Click"/>
            </Grid>

            <GroupBox Header="Files in destination" Margin="0,10,0,0" Grid.Row="2">
                <ListView x:Name="lvDestinationFiles"
              SelectionMode="Extended"
              GridViewColumnHeader.Click="GridViewColumnHeader_Click"
              FontFamily="Segoe UI Emoji">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="File Name" Tag="Name"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn>
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Modified Date" Tag="ModifiedDate"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

        </Grid>

    </Grid>
</Window>
