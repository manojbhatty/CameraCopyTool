<Window x:Class="CameraCopyTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CameraCopyTool.ViewModels"
        Title="Camera Copy Tool" Height="600" Width="1000"
        MinHeight="400" MinWidth="800"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Context menu for ListView items -->
        <ContextMenu x:Key="FileItemContextMenu">
            <MenuItem Header="Open" Click="Menu_Open_Click"/>
            <MenuItem Header="Delete" Click="Menu_Delete_Click"/>
        </ContextMenu>

        <!-- Context menu styling - matches application font size -->
        <Style TargetType="ContextMenu">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Highlight already copied items with high-contrast colors -->
        <Style TargetType="ListViewItem">
            <EventSetter Event="PreviewMouseRightButtonDown"
                         Handler="ListViewItem_PreviewMouseRightButtonDown"/>
            <Setter Property="ContextMenu" Value="{StaticResource FileItemContextMenu}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Padding" Value="5,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <!-- Already copied: High-contrast green with black text -->
                <DataTrigger Binding="{Binding IsAlreadyCopied}" Value="True">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <!-- Selected state: Prominent blue highlight with white text -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
                <!-- Mouse over: High-visibility blue highlight (only when NOT selected) -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#90CAF9"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- General fonts - uses system font settings for accessibility
             Font sizes are user-configurable via Settings dialog -->
        <Style TargetType="ListView">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="15,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <Style TargetType="Menu">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <!-- Top-level Grid -->
    <Grid>
        <!-- MENU BAR -->
        <Menu VerticalAlignment="Top">
            <MenuItem Header="_Tools" AutomationProperties.AutomationId="ToolsMenu">
                <MenuItem Header="_Update File List" Command="{Binding RefreshCommand}" AutomationProperties.AutomationId="RefreshMenu"/>
                <Separator/>
                <MenuItem Header="_Settings..." Command="{Binding OpenSettingsCommand}"/>
            </MenuItem>
        </Menu>

        <!-- MAIN CONTENT GRID -->
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SOURCE PANEL -->
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Source - Camera" FontWeight="Bold" Grid.Row="0"
                           FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Grid Margin="0,5" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Height="28"
                             Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="SourcePathTextBox"/>
                    <Button Grid.Column="1" Content="Choose Folder…" Margin="5,0,0,0" Height="28" Padding="10,3" BorderThickness="1"
                            Command="{Binding BrowseSourceCommand}"/>
                </Grid>

                <!-- Already Copied -->
                <GroupBox Header="{Binding AlreadyCopiedFilesHeader}"
                          Margin="0,10,0,5" Grid.Row="2">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <ListView x:Name="lvAlreadyCopied" SelectionMode="Extended"
                              ItemsSource="{Binding AlreadyCopiedFiles}"
                              FontFamily="Segoe UI Emoji"
                              AutomationProperties.AutomationId="AlreadyCopiedListView"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File Name">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Modified Date" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>

                <!-- New Files -->
                <GroupBox Header="{Binding NewFilesHeader}" Grid.Row="3">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <ListView x:Name="lvNewFiles" SelectionMode="Extended"
                              ItemsSource="{Binding NewFiles}"
                              FontFamily="Segoe UI Emoji"
                              AutomationProperties.AutomationId="NewFilesListView"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File Name">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Modified Date" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>

            <!-- CENTER PANEL -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Button Content="Copy ➜" Height="50" Margin="10"
                        Command="{Binding CopyCommand}"
                        FontWeight="Bold"
                        FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                        AutomationProperties.AutomationId="CopyButton"/>
                <ProgressBar Height="20" Margin="10,5"
                             Minimum="0" Maximum="{Binding ProgressMaximum}"
                             Value="{Binding ProgressValue}"/>
            </StackPanel>

            <!-- DESTINATION PANEL -->
            <Grid Grid.Column="2" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Destination - Computer" FontWeight="Bold" Grid.Row="0"
                           FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Grid Margin="0,5" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Height="28"
                             Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="DestinationPathTextBox"/>
                    <Button Grid.Column="1" Content="Choose Folder…" Margin="5,0,0,0" Height="28" Padding="10,3" BorderThickness="1"
                            Command="{Binding BrowseDestinationCommand}"/>
                </Grid>

                <GroupBox Header="{Binding DestinationFilesHeader}"
                          Margin="0,10,0,0" Grid.Row="2">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <ListView x:Name="lvDestinationFiles" SelectionMode="Extended"
                              ItemsSource="{Binding DestinationFiles}"
                              FontFamily="Segoe UI Emoji"
                              AutomationProperties.AutomationId="DestinationFilesListView"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File Name">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Modified Date" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- LOADING OVERLAY (top layer) -->
        <Grid Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100"
              IsHitTestVisible="{Binding IsLoading}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                           Margin="0,10,0,0" HorizontalAlignment="Center"
                           FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
