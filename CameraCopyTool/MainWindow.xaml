<Window x:Class="CameraCopyTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CameraCopyTool.ViewModels"
        xmlns:converters="clr-namespace:CameraCopyTool.Converters"
        Title="Camera Copy Tool" Height="600" Width="1000"
        MinHeight="400" MinWidth="800"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Boolean to Visibility converter for help panel toggle -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Boolean to Show/Hide text converter for help panel button -->
        <converters:BooleanToTextConverter x:Key="BooleanToTextConverter"/>
        
        <!-- Action button style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Help button specific style -->
        <Style x:Key="HelpButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Refresh button specific style -->
        <Style x:Key="RefreshButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#43A047"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Settings button specific style -->
        <Style x:Key="SettingsButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="#757575"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#616161"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#424242"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Context menu for ListView items -->
        <ContextMenu x:Key="FileItemContextMenu">
            <MenuItem Header="Open" Click="Menu_Open_Click"/>
            <MenuItem Header="Upload to Google Drive" Click="Menu_UploadToGoogleDrive_Click"/>
            <Separator/>
            <MenuItem Header="Delete" Click="Menu_Delete_Click"/>
        </ContextMenu>

        <!-- Pulse animation for Copy button -->
        <Storyboard x:Key="CopyButtonPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.7" Duration="0:0:1"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- Context menu styling - matches application font size -->
        <Style TargetType="ContextMenu">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Highlight already copied items with high-contrast colors -->
        <Style TargetType="ListViewItem">
            <EventSetter Event="PreviewMouseRightButtonDown"
                         Handler="ListViewItem_PreviewMouseRightButtonDown"/>
            <Setter Property="ContextMenu" Value="{StaticResource FileItemContextMenu}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Padding" Value="5,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <!-- Non-video files: Less prominent but still readable (black text at 75% opacity) -->
                <DataTrigger Binding="{Binding IsVideoFile}" Value="False">
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="Opacity" Value="0.70"/>
                </DataTrigger>
                <!-- Video files: Full prominence (black text, 100% opacity) -->
                <DataTrigger Binding="{Binding IsVideoFile}" Value="True">
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </DataTrigger>
                <!-- Already copied: High-contrast green with black text -->
                <DataTrigger Binding="{Binding IsAlreadyCopied}" Value="True">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </DataTrigger>
                <!-- Selected state: Prominent blue highlight with white text -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </Trigger>
                <!-- Mouse over: High-visibility blue highlight (only when NOT selected) -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#90CAF9"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- General fonts - uses system font settings for accessibility
             Font sizes are user-configurable via Settings dialog -->
        <Style TargetType="ListView">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="15,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <Style TargetType="Menu">
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{Binding FontSize, Mode=OneWay}"/>
        </Style>
        <!-- Base style for sortable column headers - uses default template for resize support -->
        <Style x:Key="SortableGridViewColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border x:Name="HeaderBorder"
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <ContentPresenter x:Name="HeaderContent"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,25,0"/>
                                    <TextBlock x:Name="SortIndicator"
                                               Text="▲"
                                               FontSize="10"
                                               Foreground="#1976D2"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,10,0"/>
                                </Grid>
                            </Border>
                            <!-- Resize thumb - MUST be at Grid level, not inside Border -->
                            <Thumb x:Name="PART_HeaderGrip" 
                                   HorizontalAlignment="Right"
                                   Width="16"
                                   Cursor="SizeWE"
                                   PreviewMouseLeftButtonDown="Thumb_PreviewMouseLeftButtonDown">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Grid Width="16" HorizontalAlignment="Right">
                                            <!-- Visual indicator line -->
                                            <Border x:Name="ResizeLine" 
                                                    Width="2" 
                                                    Background="Transparent"
                                                    HorizontalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ResizeLine" Property="Background" Value="#64B5F6"/>
                                            </Trigger>
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter TargetName="ResizeLine" Property="Background" Value="#1976D2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#BBDEFB"/>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#64B5F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>

    <!-- Top-level Grid -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Action Button Bar: 50px -->
            <RowDefinition Height="Auto"/>
            <!-- Help Panel: 180px when expanded, 0 when collapsed -->
            <RowDefinition Height="*"/>
            <!-- Main Content: takes remaining space -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar: 30px -->
        </Grid.RowDefinitions>

        <!-- ACTION BUTTONS BAR (Row 0) -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left side: Refresh button -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Refresh (F5)"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource RefreshButtonStyle}"
                            Margin="0,0,10,0"/>
                </StackPanel>

                <!-- Right side: Settings and Help buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚙️ Settings"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource SettingsButtonStyle}"
                            Margin="0,0,10,0"/>
                    <Button Content="❓ How to Use"
                            Command="{Binding ToggleHelpCommand}"
                            Style="{StaticResource HelpButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- COLLAPSIBLE HELP PANEL (Row 1) -->
        <Border Grid.Row="1" Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Height" Value="220"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowHelpPanel}" Value="False">
                            <Setter Property="Height" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Margin="20,15" Visibility="{Binding ShowHelpPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Instructions - Two Column Layout -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Copy Instructions -->
                    <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="Bold" 
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,0,0,5">📋 To Copy Videos:</TextBlock>
                        <TextBlock Text="1. Select your camera folder using 'Select Folder…'"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                        <TextBlock Text="2. Select your computer folder using 'Select Folder…'"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                        <TextBlock Text="3. Select the photos you want to copy (click on them)"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                        <TextBlock Text="4. Click the big green 'Copy' button"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                    </StackPanel>

                    <!-- Right Column: Delete Instructions -->
                    <StackPanel Grid.Column="2">
                        <TextBlock FontWeight="Bold"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,0,0,5">🗑️ To Delete Files:</TextBlock>
                        <TextBlock Text="1. Select file(s) to delete in any list"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                        <TextBlock Text="2. Press Delete key or right-click → Delete"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                        <TextBlock Text="3. Confirm (⚠️ This is permanent!)"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Margin="0,2"/>
                    </StackPanel>
                </Grid>

                <!-- Color Legend - Bottom -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="✓ " Foreground="#4CAF50" FontWeight="Bold"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBlock Text="Already copied = GREEN"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="Bold" Foreground="#2E7D32"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓ " Foreground="#1976D2" FontWeight="Bold"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <TextBlock Text="New files = BLUE"
                                   FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="Bold" Foreground="#1565C0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STATUS BAR (Row 3) -->
        <StatusBar Grid.Row="3" Height="30"
                   Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0" Padding="10,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusBarIcon}" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusBarText}" FontSize="13" FontWeight="Medium"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Grid.Column="1" Width="1" Margin="5,5"/>
            <StatusBarItem Grid.Column="2" Padding="10,5">
                <TextBlock Text="{Binding SourceFileCountText}" FontSize="13"/>
            </StatusBarItem>
            <Separator Grid.Column="3" Width="1" Margin="5,5"/>
            <StatusBarItem Grid.Column="4" Padding="10,5">
                <TextBlock Text="{Binding NewFileCountText}" FontSize="13" FontWeight="Bold" Foreground="#1976D2"/>
            </StatusBarItem>
        </StatusBar>

        <!-- MAIN CONTENT GRID (Row 2, with visual separators) -->
        <Grid Grid.Row="2" Margin="20,10,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Visual Separators between panels -->
            <Border Grid.Column="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0" CornerRadius="4"/>
            <Border Grid.Column="2" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="1,0,0,0" CornerRadius="4"/>

            <!-- SOURCE PANEL -->
            <Grid Grid.Column="0" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📷 Your Camera Videos" FontWeight="Bold" Grid.Row="0"
                           FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Grid Margin="0,5" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding RecentSourceFolders}"
                              Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              StaysOpenOnEdit="True"
                              AutomationProperties.AutomationId="SourcePathTextBox"
                              MaxDropDownHeight="200">
                        <ComboBox.ToolTip>
                            <ToolTip Content="Select from recent folders or type a path"/>
                        </ComboBox.ToolTip>
                    </ComboBox>
                    <Button Grid.Column="1" Content="📁 Select Folder…" Margin="5,0,0,0"
                            Command="{Binding BrowseSourceCommand}"
                            Background="#E0E0E0"
                            Foreground="#424242"
                            FontSize="12"
                            Padding="8,4"
                            BorderThickness="1"
                            BorderBrush="#BDBDBD">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                        <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#9E9E9E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Already Copied (Collapsible) -->
                <Border Grid.Row="2" Margin="0,10,0,5" Background="#E8F5E9" BorderBrush="#81C784" BorderThickness="1" CornerRadius="4">
                    <Expander Header="{Binding AlreadyCopiedFilesHeader}"
                              IsExpanded="False"
                              Background="Transparent">
                        <Expander.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="Bold"/>
                            </DataTemplate>
                        </Expander.HeaderTemplate>
                        <ListView x:Name="lvAlreadyCopied" SelectionMode="Extended"
                                  ItemsSource="{Binding AlreadyCopiedFiles}"
                                  FontFamily="Segoe UI Emoji"
                                  AutomationProperties.AutomationId="AlreadyCopiedListView"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File Name">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style BasedOn="{StaticResource SortableGridViewColumnHeader}" TargetType="GridViewColumnHeader">
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridViewColumnHeader_PreviewMouseLeftButtonDown"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Modified Date" Width="200">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style BasedOn="{StaticResource SortableGridViewColumnHeader}" TargetType="GridViewColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridViewColumnHeader_PreviewMouseLeftButtonDown"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Expander>
                </Border>

                <!-- New Files -->
                <Border Grid.Row="3" Background="#E3F2FD" BorderBrush="#64B5F6" BorderThickness="1" CornerRadius="4" Margin="0,5,0,0">
                    <GroupBox Header="{Binding NewFilesHeader}"
                              Background="Transparent"
                              BorderThickness="0">
                        <GroupBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataTemplate>
                        </GroupBox.HeaderTemplate>
                        <ListView x:Name="lvNewFiles" SelectionMode="Extended"
                                  ItemsSource="{Binding NewFiles}"
                                  FontFamily="Segoe UI Emoji"
                                  AutomationProperties.AutomationId="NewFilesListView"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File Name">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style BasedOn="{StaticResource SortableGridViewColumnHeader}" TargetType="GridViewColumnHeader">
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridViewColumnHeader_PreviewMouseLeftButtonDown"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Modified Date" Width="200">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style BasedOn="{StaticResource SortableGridViewColumnHeader}" TargetType="GridViewColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridViewColumnHeader_PreviewMouseLeftButtonDown"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
                </Border>
            </Grid>

            <!-- CENTER PANEL -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Button x:Name="CopyButton" Height="90" Margin="10"
                        Command="{Binding CopyCommand}"
                        FontWeight="Bold"
                        Background="#4CAF50"
                        BorderThickness="2"
                        BorderBrush="#388E3C"
                        Padding="20,10"
                        AutomationProperties.AutomationId="CopyButton">
                    <Button.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Copy" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="➜" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="FontFamily" Value="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#43A047"/>
                                    <Setter Property="BorderBrush" Value="#2E7D32"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="#A0A0A0"/>
                                    <Setter Property="BorderBrush" Value="#C0C0C0"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Grid Height="30" Margin="10,5">
                    <ProgressBar x:Name="CopyProgressBar" Minimum="0"
                                 Maximum="{Binding ProgressMaximum}"
                                 Value="{Binding ProgressValue}"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 Panel.ZIndex="0"/>
                    <TextBlock x:Name="ProgressText" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="Bold" FontSize="14" Foreground="#000000"
                               Text="{Binding ProgressPercentage, StringFormat={}{0:F0}%}"
                               Panel.ZIndex="1"/>
                </Grid>
            </StackPanel>

            <!-- DESTINATION PANEL -->
            <Grid Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="💻 Your Computer Videos" FontWeight="Bold" Grid.Row="0"
                           FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Grid Margin="0,5" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding RecentDestinationFolders}"
                              Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              StaysOpenOnEdit="True"
                              AutomationProperties.AutomationId="DestinationPathTextBox"
                              MaxDropDownHeight="200">
                        <ComboBox.ToolTip>
                            <ToolTip Content="Select from recent folders or type a path"/>
                        </ComboBox.ToolTip>
                    </ComboBox>
                    <Button Grid.Column="1" Content="📁 Select Folder…" Margin="5,0,0,0"
                            Command="{Binding BrowseDestinationCommand}"
                            Background="#E0E0E0"
                            Foreground="#424242"
                            FontSize="12"
                            Padding="8,4"
                            BorderThickness="1"
                            BorderBrush="#BDBDBD">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#BDBDBD"/>
                                        <Setter Property="BorderBrush" Value="#9E9E9E"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#9E9E9E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <GroupBox Header="{Binding DestinationFilesHeader}"
                          Margin="0,10,0,0" Grid.Row="2">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <ListView x:Name="lvDestinationFiles" SelectionMode="Extended"
                              ItemsSource="{Binding DestinationFiles}"
                              FontFamily="Segoe UI Emoji"
                              AutomationProperties.AutomationId="DestinationFilesListView"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="File Name">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style BasedOn="{StaticResource SortableGridViewColumnHeader}" TargetType="GridViewColumnHeader">
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridViewColumnHeader_PreviewMouseLeftButtonDown"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Modified Date" Width="200">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style BasedOn="{StaticResource SortableGridViewColumnHeader}" TargetType="GridViewColumnHeader">
                                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridViewColumnHeader_PreviewMouseLeftButtonDown"/>
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModifiedDate}" HorizontalAlignment="Right" FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- LOADING OVERLAY (top layer) -->
        <Grid Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100"
              IsHitTestVisible="{Binding IsLoading}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White"
                           Margin="0,10,0,0" HorizontalAlignment="Center"
                           FontSize="{Binding DataContext.FontSize, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
